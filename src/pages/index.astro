---
import BaseLayout from '../layouts/BaseLayout.astro';
import EraSlider from '../components/EraSlider';
---
<BaseLayout title="金沢城 Interactive Map">
  <main style="padding: 2rem 1rem;">
    <h1 style="text-align:center; font-size:1.4rem; color:#2a1f0f; margin-bottom:0.5rem;">
      金沢城
    </h1>
    <p style="text-align:center; font-size:0.85rem; color:#6a5a4a; margin-bottom:1.5rem;">
      시대별 성곽 변천 지도
    </p>
    <EraSlider client:load />
  </main>
</BaseLayout>
